#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

INCOGNITO=false
SESSION_DIR=""
MODEL=""
PICK_MODEL=false

# Parse arguments, intercept our flags
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --resume)     ARGS+=("--resume"); shift ;;
    -c)           ARGS+=("--continue"); shift ;;
    --incognito)  INCOGNITO=true; shift ;;
    --session-dir)
      SESSION_DIR="$2"; shift 2 ;;
    --model=*)    MODEL="${1#--model=}"; shift ;;
    --model)      MODEL="$2"; shift 2 ;;
    --setup)      PICK_MODEL=true; shift ;;
    --sessions)   shift ;; # backward compat no-op
    *)            ARGS+=("$1"); shift ;;
  esac
done

# Read saved model from .env
saved_model() {
  grep '^ANTHROPIC_DEFAULT_SONNET_MODEL=' "$ENV_FILE" 2>/dev/null | cut -d= -f2-
}

# Save model to .env
save_model() {
  local model="$1"
  if [ ! -f "$ENV_FILE" ]; then
    cp "$SCRIPT_DIR/.env.example" "$ENV_FILE"
  fi
  for var in ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_SONNET_MODEL ANTHROPIC_DEFAULT_HAIKU_MODEL CLAUDE_CODE_SUBAGENT_MODEL; do
    if grep -q "^${var}=" "$ENV_FILE"; then
      sed -i '' "s|^${var}=.*|${var}=$model|" "$ENV_FILE"
    else
      echo "${var}=$model" >> "$ENV_FILE"
    fi
  done
}

# Model picker (gum or numbered fallback)
pick_model() {
  local MODELS_FILE="$SCRIPT_DIR/models.json"
  [ -f "$MODELS_FILE" ] || return

  if command -v gum &>/dev/null; then
    LINES=()
    IDS=()
    while IFS='|' read -r id line; do
      IDS+=("$id")
      LINES+=("$line")
    done < <(python3 -c "
import json
with open('$MODELS_FILE') as f:
    models = json.load(f)
for m in models:
    ctx = m['context']
    ctx_str = f'{ctx/1000000:.0f}M' if ctx >= 1000000 else f'{ctx/1000:.0f}K'
    print(f\"{m['id']}|{m['name']:<35s} {ctx_str:>5s}  {m['pricing']}\")
")

    SELECTED=$(printf '%s\n' "${LINES[@]}" | gum choose \
      --header "⚡ OpenRouter — Select a model" \
      --header.foreground="6" \
      --cursor.foreground="3" \
      --selected.foreground="2") || true

    if [ -n "$SELECTED" ]; then
      for i in "${!LINES[@]}"; do
        if [ "${LINES[$i]}" = "$SELECTED" ]; then
          MODEL="${IDS[$i]}"
          return
        fi
      done
    fi
  else
    # Fallback: numbered list
    IDS=()
    NAMES=()
    while IFS='|' read -r id line; do
      IDS+=("$id")
      NAMES+=("$line")
    done < <(python3 -c "
import json
with open('$MODELS_FILE') as f:
    models = json.load(f)
for m in models:
    ctx = m['context']
    ctx_str = f'{ctx/1000000:.0f}M' if ctx >= 1000000 else f'{ctx/1000:.0f}K'
    print(f\"{m['id']}|{m['name']:<35s} {ctx_str:>5s}  {m['pricing']}\")
")

    echo "⚡ OpenRouter — Select a model:"
    echo ""
    for i in "${!IDS[@]}"; do
      printf "  %2d) %s\n" $((i+1)) "${NAMES[$i]}"
    done
    echo ""
    read -rp "Choice [1]: " choice
    choice=${choice:-1}
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#IDS[@]}" ]; then
      MODEL="${IDS[$((choice-1))]}"
    else
      MODEL="${IDS[0]}"
    fi
  fi
}

# Determine model: --model flag > --setup picker > saved in .env > first-time picker
if [ -n "$MODEL" ]; then
  save_model "$MODEL"
elif [ "$PICK_MODEL" = true ] && [ -t 0 ]; then
  pick_model
  [ -n "$MODEL" ] && save_model "$MODEL"
elif [ -z "$(saved_model)" ] && [ -t 0 ]; then
  pick_model
  [ -n "$MODEL" ] && save_model "$MODEL"
fi

# Model env overrides (if selected via flag or picker, override .env for this run)
MODEL_ENVS=()
if [ -n "$MODEL" ]; then
  MODEL_ENVS=(
    "-e" "ANTHROPIC_DEFAULT_OPUS_MODEL=$MODEL"
    "-e" "ANTHROPIC_DEFAULT_SONNET_MODEL=$MODEL"
    "-e" "ANTHROPIC_DEFAULT_HAIKU_MODEL=$MODEL"
    "-e" "CLAUDE_CODE_SUBAGENT_MODEL=$MODEL"
  )
fi

VOLUMES=(
  "-v" "$(pwd):/workspace"
)

if [ "$INCOGNITO" = false ]; then
  SESSION_DIR="${SESSION_DIR:-$(pwd)/.opclaude/sessions}"
  mkdir -p "$SESSION_DIR/sessions" "$SESSION_DIR/projects"
  VOLUMES+=(
    "-v" "$SESSION_DIR/sessions:/home/claude/.claude/sessions:rw"
    "-v" "$SESSION_DIR/projects:/home/claude/.claude/projects:rw"
  )
fi

exec docker run -it --rm \
  --env-file "$SCRIPT_DIR/.env" \
  -e ANTHROPIC_BASE_URL="https://openrouter.ai/api" \
  -e ANTHROPIC_API_KEY="" \
  -e TERM="xterm-256color" \
  ${MODEL_ENVS[@]+"${MODEL_ENVS[@]}"} \
  "${VOLUMES[@]}" \
  claude-openrouter ${ARGS[@]+"${ARGS[@]}"}
